<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>홈 화면</title>

    <style>
        * {
            margin: 0;
            padding: 0;
        }

        .container {
            position: relative;
        }

        .box {
            margin: auto;
            width: 500px;
            height: 300px;
            position: absolute;
            top: 100px;
            left: 50%;
            transform: translate(-50%, 0);
            border-radius: 10px;
            display: flex;
        }

        .welcome-box {
            width: 60%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: start;
            padding-left: 30px;
            box-shadow: 0 0px 70px rgba(0, 0, 0, 0.1);
            border-top: 5px solid #4668CF;
        }

        .nav-box {
            width: 40%;
            box-shadow: 0 0px 20px rgba(0, 0, 0, 0.03);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 15px; /* 버튼 사이 간격 */
        }

        .btn-primary {
            background-color: #4668CF;
            color: white;
            border-radius: 5px;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
            width: 70%;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            text-decoration: none;
            box-sizing: border-box;
        }

        .btn-primary:hover {
            filter: contrast(80%);
        }

        .btn-secondary {
            background-color: white;
            color: rgb(73, 73, 73);
            border: 2px solid rgb(191, 191, 191);
            border-radius: 5px;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 8px;
            width: 70%;
            cursor: pointer;
            font-size: 15px;
            text-decoration: none;
            box-sizing: border-box;
        }

        .btn-secondary:hover {
            filter: opacity(0.6);
        }

    </style>
</head>

<body>
<div class="container">
    <div class="box">
        {{#sessionUser}}
            <div class="welcome-box">
                <h1 style="color: #4668CF; font-size: 32px; margin-bottom: 10px;">Cafe Spring</h1>
                <h3 style="color: #5770bb; font-size: 16px; margin-top: 20px;">{{firstName}}님 안녕하세요!</h3>
            </div>

            <div class="nav-box">
                <a href="/logout" class="btn-primary">Logout</a>
                <a href="/modify" class="btn-secondary">Modify Info</a>
                <a href="/list" class="btn-secondary">User List</a>
            </div>
        {{/sessionUser}}

        {{^sessionUser}}
        <div class="welcome-box">
            <h1 style="color: #4668CF; font-size: 32px; margin-bottom: 10px;">Cafe Spring</h1>
        </div>

        <div class="nav-box">
            <a href="/login" class="btn-primary">Log in</a>
            <a href="/signup" class="btn-secondary">Sign Up</a>
            <a href="/list" class="btn-secondary">User List</a>
        </div>
        {{/sessionUser}}
    </div>
</div>
</body>